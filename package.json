{
  "name": "iphone-photo-bridge",
  "version": "1.1.0",
  "description": "Temporary PIN-protected photo album transfer app for iPhone to PC from a private GitHub repository and local PC.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "check": "node --check server.js",
    "check:app": "node --check public/app.js",
    "urls": "node scripts/print_network_urls.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "qrcode": "^1.5.4"
  }
}
